{
  "name": "my-backend",
  "version": "1.0.0",
  "description": "Backend for my album review app",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start:dbserver": "node servers/dbserver.js",
    "start:server": "node servers/server.js",
    "start:tidalserver": "node servers/tidalserver/tidalserver.js",
    "start": "npm run start:server",
    "tidal": "npm run start:tidalserver",
    "start:all": "concurrently \"npm run start:dbserver\" \"npm run start:server\"",
    "dev": "concurrently \"nodemon servers/dbserver.js\" \"nodemon servers/server.js\" \"nodemon servers/tidalserver/tidalserver.js\""
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.22.1",
    "mysql2": "^3.1.0",
    "pg": "^8.10.0",
    "concurrently": "^9.1.2"
  },
  "devDependencies": {}
}
